<launch>
    <!-- Arguments -->
    <arg name="cmd_vel_topic" default="/cmd_vel" />
    <arg name="odom_topic" default="odom" />
    <arg name="move_forward_only" default="false"/>

    <!-- move_base -->
    <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
        <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS" />
        <param name="base_global_planner" value="global_planner/GlobalPlanner" />
        
        <rosparam file="$(find nav_bringup)/config/costmap_common_params.yaml" command="load" ns="global_costmap" />
        <rosparam file="$(find nav_bringup)/config/costmap_common_params.yaml" command="load" ns="local_costmap" />
        <rosparam file="$(find nav_bringup)/config/local_costmap_params.yaml" command="load" />
        <rosparam file="$(find nav_bringup)/config/global_costmap_params.yaml" command="load" />
        <rosparam file="$(find nav_bringup)/config/dwa_local_planner_params.yaml" command="load" />
        
        <param name="DWAPlannerROS/min_vel_x" value="0.0" if="$(arg move_forward_only)" />
        <remap from="cmd_vel" to="$(arg cmd_vel_topic)"/>
        <remap from="odom" to="$(arg odom_topic)"/>
    </node>
</launch>
